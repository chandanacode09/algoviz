{
  "version": "1.0",
  "metadata": {
    "algorithm": "merge_sort",
    "title": "Merge Sort",
    "description": "Divide the array in half recursively, then merge sorted halves back together. Demonstrates the divide-and-conquer pattern.",
    "category": "sorting",
    "complexity": { "time": "O(n log n)", "space": "O(n)", "best": "O(n log n)", "worst": "O(n log n)" },
    "difficulty": "intermediate",
    "inputDescription": "Array: [5, 2, 8, 1, 9, 3]",
    "tags": ["sorting", "divide-and-conquer", "stable", "recursive"]
  },
  "config": {
    "canvas": { "width": 1000, "height": 550 },
    "playback": { "stepDuration": 900 }
  },
  "actors": [
    { "id": "c0", "type": "cell", "x": 200, "y": 80, "width": 70, "height": 60, "value": 5, "sublabel": "0" },
    { "id": "c1", "type": "cell", "x": 290, "y": 80, "width": 70, "height": 60, "value": 2, "sublabel": "1" },
    { "id": "c2", "type": "cell", "x": 380, "y": 80, "width": 70, "height": 60, "value": 8, "sublabel": "2" },
    { "id": "c3", "type": "cell", "x": 470, "y": 80, "width": 70, "height": 60, "value": 1, "sublabel": "3" },
    { "id": "c4", "type": "cell", "x": 560, "y": 80, "width": 70, "height": 60, "value": 9, "sublabel": "4" },
    { "id": "c5", "type": "cell", "x": 650, "y": 80, "width": 70, "height": 60, "value": 3, "sublabel": "5" },

    { "id": "title", "type": "label", "x": 500, "y": 30, "text": "Merge Sort — [5, 2, 8, 1, 9, 3]", "fontSize": 22, "fontWeight": "bold", "anchor": "middle" },
    { "id": "status", "type": "label", "x": 500, "y": 510, "text": "Input array. We'll divide, then merge sorted halves.", "fontSize": 15, "anchor": "middle", "fill": "$muted" },
    { "id": "phase", "type": "label", "x": 500, "y": 480, "text": "Phase: DIVIDE", "fontSize": 14, "fontWeight": "bold", "anchor": "middle", "fill": "$primary" },

    { "id": "left-label", "type": "label", "x": 280, "y": 180, "text": "", "fontSize": 13, "anchor": "middle", "fill": "$muted" },
    { "id": "right-label", "type": "label", "x": 630, "y": 180, "text": "", "fontSize": 13, "anchor": "middle", "fill": "$muted" },

    { "id": "m0", "type": "cell", "x": 200, "y": 320, "width": 70, "height": 60, "value": "", "label": "", "opacity": 0, "sublabel": "0" },
    { "id": "m1", "type": "cell", "x": 290, "y": 320, "width": 70, "height": 60, "value": "", "label": "", "opacity": 0, "sublabel": "1" },
    { "id": "m2", "type": "cell", "x": 380, "y": 320, "width": 70, "height": 60, "value": "", "label": "", "opacity": 0, "sublabel": "2" },
    { "id": "m3", "type": "cell", "x": 470, "y": 320, "width": 70, "height": 60, "value": "", "label": "", "opacity": 0, "sublabel": "3" },
    { "id": "m4", "type": "cell", "x": 560, "y": 320, "width": 70, "height": 60, "value": "", "label": "", "opacity": 0, "sublabel": "4" },
    { "id": "m5", "type": "cell", "x": 650, "y": 320, "width": 70, "height": 60, "value": "", "label": "", "opacity": 0, "sublabel": "5" },

    { "id": "merge-label", "type": "label", "x": 500, "y": 300, "text": "", "fontSize": 14, "fontWeight": "bold", "anchor": "middle", "fill": "$primary" }
  ],
  "steps": [
    {
      "description": "Split array into left half [5, 2, 8] and right half [1, 9, 3]",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$primary" } },
        { "type": "update", "target": "c1", "props": { "fill": "$primary" } },
        { "type": "update", "target": "c2", "props": { "fill": "$primary" } },
        { "type": "update", "target": "c3", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c4", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c5", "props": { "fill": "$warning" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [5, 2, 8]" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [1, 9, 3]" } },
        { "type": "update", "target": "status", "props": { "text": "Divide array at midpoint (index 3). Left=[5,2,8], Right=[1,9,3]" } }
      ]
    },
    {
      "description": "Recursively sort left half: [5, 2, 8] → split into [5] and [2, 8]",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$success" } },
        { "type": "update", "target": "c1", "props": { "fill": "$danger" } },
        { "type": "update", "target": "c2", "props": { "fill": "$danger" } },
        { "type": "update", "target": "c3", "props": { "fill": "$default", "opacity": 0.4 } },
        { "type": "update", "target": "c4", "props": { "fill": "$default", "opacity": 0.4 } },
        { "type": "update", "target": "c5", "props": { "fill": "$default", "opacity": 0.4 } },
        { "type": "update", "target": "left-label", "props": { "text": "[5] already sorted | [2, 8] needs sorting" } },
        { "type": "update", "target": "right-label", "props": { "text": "" } },
        { "type": "update", "target": "status", "props": { "text": "[5] is a single element (already sorted). Now sort [2, 8]." } }
      ]
    },
    {
      "description": "Sort [2, 8]: already in order. Merge [5] + [2, 8] → [2, 5, 8]",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$success" } },
        { "type": "update", "target": "c1", "props": { "fill": "$success" } },
        { "type": "update", "target": "c2", "props": { "fill": "$success" } },
        { "type": "update", "target": "c0", "props": { "value": 2, "label": "2" } },
        { "type": "update", "target": "c1", "props": { "value": 5, "label": "5" } },
        { "type": "update", "target": "c2", "props": { "value": 8, "label": "8" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left sorted: [2, 5, 8] ✓" } },
        { "type": "update", "target": "status", "props": { "text": "Merge [5] and [2,8]: compare 5>2, so 2 goes first → [2, 5, 8]" } },
        { "type": "update", "target": "phase", "props": { "text": "Phase: MERGE (left half)" } }
      ],
      "transition": "swap"
    },
    {
      "description": "Now sort right half: [1, 9, 3] → split into [1] and [9, 3]",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$default", "opacity": 0.4 } },
        { "type": "update", "target": "c1", "props": { "fill": "$default", "opacity": 0.4 } },
        { "type": "update", "target": "c2", "props": { "fill": "$default", "opacity": 0.4 } },
        { "type": "update", "target": "c3", "props": { "fill": "$success", "opacity": 1 } },
        { "type": "update", "target": "c4", "props": { "fill": "$danger", "opacity": 1 } },
        { "type": "update", "target": "c5", "props": { "fill": "$danger", "opacity": 1 } },
        { "type": "update", "target": "left-label", "props": { "text": "" } },
        { "type": "update", "target": "right-label", "props": { "text": "[1] sorted | [9, 3] needs sorting" } },
        { "type": "update", "target": "status", "props": { "text": "[1] is single (sorted). Now sort [9, 3]." } },
        { "type": "update", "target": "phase", "props": { "text": "Phase: DIVIDE (right half)" } }
      ]
    },
    {
      "description": "Sort [9, 3]: 9 > 3, swap → [3, 9]. Merge [1] + [3, 9] → [1, 3, 9]",
      "actions": [
        { "type": "update", "target": "c3", "props": { "fill": "$success", "value": 1, "label": "1" } },
        { "type": "update", "target": "c4", "props": { "fill": "$success", "value": 3, "label": "3" } },
        { "type": "update", "target": "c5", "props": { "fill": "$success", "value": 9, "label": "9" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right sorted: [1, 3, 9] ✓" } },
        { "type": "update", "target": "status", "props": { "text": "Merge [1] and [3,9]: 1<3, so 1 first → [1, 3, 9]" } },
        { "type": "update", "target": "phase", "props": { "text": "Phase: MERGE (right half)" } }
      ],
      "transition": "swap"
    },
    {
      "description": "Final merge: combine sorted [2, 5, 8] and [1, 3, 9]. Compare heads: 1 < 2 → take 1",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$primary", "opacity": 1 } },
        { "type": "update", "target": "c1", "props": { "fill": "$default", "opacity": 1 } },
        { "type": "update", "target": "c2", "props": { "fill": "$default", "opacity": 1 } },
        { "type": "update", "target": "c3", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c4", "props": { "fill": "$default" } },
        { "type": "update", "target": "c5", "props": { "fill": "$default" } },
        { "type": "update", "target": "merge-label", "props": { "text": "Merging into output array ↓" } },
        { "type": "update", "target": "m0", "props": { "value": 1, "label": "1", "opacity": 1, "fill": "$success" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [2, 5, 8]" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [1←, 3, 9]" } },
        { "type": "update", "target": "status", "props": { "text": "Compare 2 vs 1: 1 < 2, take 1 from right. Output: [1]" } },
        { "type": "update", "target": "phase", "props": { "text": "Phase: FINAL MERGE" } }
      ]
    },
    {
      "description": "Compare heads: 2 < 3 → take 2 from left",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c3", "props": { "fill": "$default", "opacity": 0.3 } },
        { "type": "update", "target": "c4", "props": { "fill": "$primary" } },
        { "type": "update", "target": "m1", "props": { "value": 2, "label": "2", "opacity": 1, "fill": "$success" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [2←, 5, 8]" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [3, 9]" } },
        { "type": "update", "target": "status", "props": { "text": "Compare 2 vs 3: 2 < 3, take 2 from left. Output: [1, 2]" } }
      ]
    },
    {
      "description": "Compare heads: 5 > 3 → take 3 from right",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$default", "opacity": 0.3 } },
        { "type": "update", "target": "c1", "props": { "fill": "$primary" } },
        { "type": "update", "target": "c4", "props": { "fill": "$warning" } },
        { "type": "update", "target": "m2", "props": { "value": 3, "label": "3", "opacity": 1, "fill": "$success" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [5, 8]" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [3←, 9]" } },
        { "type": "update", "target": "status", "props": { "text": "Compare 5 vs 3: 3 < 5, take 3 from right. Output: [1, 2, 3]" } }
      ]
    },
    {
      "description": "Compare heads: 5 < 9 → take 5 from left",
      "actions": [
        { "type": "update", "target": "c1", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c4", "props": { "fill": "$default", "opacity": 0.3 } },
        { "type": "update", "target": "c5", "props": { "fill": "$primary" } },
        { "type": "update", "target": "m3", "props": { "value": 5, "label": "5", "opacity": 1, "fill": "$success" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [5←, 8]" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [9]" } },
        { "type": "update", "target": "status", "props": { "text": "Compare 5 vs 9: 5 < 9, take 5 from left. Output: [1, 2, 3, 5]" } }
      ]
    },
    {
      "description": "Compare heads: 8 < 9 → take 8 from left",
      "actions": [
        { "type": "update", "target": "c1", "props": { "fill": "$default", "opacity": 0.3 } },
        { "type": "update", "target": "c2", "props": { "fill": "$warning" } },
        { "type": "update", "target": "m4", "props": { "value": 8, "label": "8", "opacity": 1, "fill": "$success" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [8←]" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [9]" } },
        { "type": "update", "target": "status", "props": { "text": "Compare 8 vs 9: 8 < 9, take 8 from left. Output: [1, 2, 3, 5, 8]" } }
      ]
    },
    {
      "description": "Left exhausted. Take remaining 9 from right",
      "actions": [
        { "type": "update", "target": "c2", "props": { "fill": "$default", "opacity": 0.3 } },
        { "type": "update", "target": "c5", "props": { "fill": "$warning" } },
        { "type": "update", "target": "m5", "props": { "value": 9, "label": "9", "opacity": 1, "fill": "$success" } },
        { "type": "update", "target": "left-label", "props": { "text": "Left: [] (empty)" } },
        { "type": "update", "target": "right-label", "props": { "text": "Right: [9←]" } },
        { "type": "update", "target": "status", "props": { "text": "Left half exhausted. Append remaining 9. Output: [1, 2, 3, 5, 8, 9]" } }
      ]
    },
    {
      "description": "Merge sort complete! Array sorted: [1, 2, 3, 5, 8, 9]",
      "actions": [
        { "type": "update", "target": "c0", "props": { "opacity": 0.15 } },
        { "type": "update", "target": "c1", "props": { "opacity": 0.15 } },
        { "type": "update", "target": "c2", "props": { "opacity": 0.15 } },
        { "type": "update", "target": "c3", "props": { "opacity": 0.15 } },
        { "type": "update", "target": "c4", "props": { "opacity": 0.15 } },
        { "type": "update", "target": "c5", "props": { "opacity": 0.15 } },
        { "type": "update", "target": "m0", "props": { "fill": "$success" } },
        { "type": "update", "target": "m1", "props": { "fill": "$success" } },
        { "type": "update", "target": "m2", "props": { "fill": "$success" } },
        { "type": "update", "target": "m3", "props": { "fill": "$success" } },
        { "type": "update", "target": "m4", "props": { "fill": "$success" } },
        { "type": "update", "target": "m5", "props": { "fill": "$success" } },
        { "type": "update", "target": "merge-label", "props": { "text": "✓ Sorted Result" } },
        { "type": "update", "target": "left-label", "props": { "text": "" } },
        { "type": "update", "target": "right-label", "props": { "text": "" } },
        { "type": "update", "target": "status", "props": { "text": "Merge sort complete! [5,2,8,1,9,3] → [1,2,3,5,8,9] in O(n log n) time." } },
        { "type": "update", "target": "phase", "props": { "text": "✓ SORTED", "fill": "$success" } }
      ]
    }
  ]
}

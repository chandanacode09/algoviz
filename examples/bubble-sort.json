{
  "version": "1.0",
  "metadata": {
    "algorithm": "bubble_sort",
    "title": "Bubble Sort",
    "description": "Repeatedly steps through the list, compares adjacent elements, and swaps them if they are in the wrong order. The pass through the list is repeated until the list is sorted.",
    "category": "sorting",
    "complexity": {
      "time": "O(n²)",
      "space": "O(1)",
      "best": "O(n)",
      "worst": "O(n²)",
      "average": "O(n²)"
    },
    "difficulty": "beginner",
    "inputDescription": "Array: [5, 3, 8, 1]",
    "author": "claude",
    "tags": ["sorting", "comparison", "in-place", "stable"]
  },
  "config": {
    "canvas": { "width": 1000, "height": 400 },
    "playback": { "stepDuration": 1000 }
  },
  "actors": [
    { "id": "c0", "type": "cell", "x": 310, "y": 160, "width": 80, "height": 80, "value": 5, "sublabel": "0" },
    { "id": "c1", "type": "cell", "x": 410, "y": 160, "width": 80, "height": 80, "value": 3, "sublabel": "1" },
    { "id": "c2", "type": "cell", "x": 510, "y": 160, "width": 80, "height": 80, "value": 8, "sublabel": "2" },
    { "id": "c3", "type": "cell", "x": 610, "y": 160, "width": 80, "height": 80, "value": 1, "sublabel": "3" },
    { "id": "title", "type": "label", "x": 500, "y": 40, "text": "Bubble Sort", "fontSize": 24, "fontWeight": "bold", "anchor": "middle" },
    { "id": "status", "type": "label", "x": 500, "y": 340, "text": "Starting: [5, 3, 8, 1]", "fontSize": 16, "anchor": "middle", "fill": "$muted" },
    { "id": "pass_label", "type": "label", "x": 500, "y": 80, "text": "", "fontSize": 14, "anchor": "middle", "fill": "$muted" }
  ],
  "steps": [
    {
      "description": "Pass 1: Compare elements at index 0 and 1",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c1", "props": { "fill": "$warning" } },
        { "type": "update", "target": "status", "props": { "text": "Compare: 5 > 3?" } },
        { "type": "update", "target": "pass_label", "props": { "text": "Pass 1 of 3" } }
      ],
      "transition": "highlight"
    },
    {
      "description": "5 > 3 is true — swap them",
      "actions": [
        { "type": "update", "target": "c0", "props": { "value": 3, "label": "3", "fill": "$danger" } },
        { "type": "update", "target": "c1", "props": { "value": 5, "label": "5", "fill": "$danger" } },
        { "type": "update", "target": "status", "props": { "text": "Yes! Swap 5 and 3 → [3, 5, 8, 1]" } }
      ],
      "transition": "swap"
    },
    {
      "description": "Reset colors. Compare elements at index 1 and 2",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$default" } },
        { "type": "update", "target": "c1", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c2", "props": { "fill": "$warning" } },
        { "type": "update", "target": "status", "props": { "text": "Compare: 5 > 8?" } }
      ],
      "transition": "highlight"
    },
    {
      "description": "5 > 8 is false — no swap needed",
      "actions": [
        { "type": "update", "target": "c1", "props": { "fill": "$default" } },
        { "type": "update", "target": "c2", "props": { "fill": "$default" } },
        { "type": "update", "target": "status", "props": { "text": "No. 5 ≤ 8, no swap needed" } }
      ]
    },
    {
      "description": "Compare elements at index 2 and 3",
      "actions": [
        { "type": "update", "target": "c2", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c3", "props": { "fill": "$warning" } },
        { "type": "update", "target": "status", "props": { "text": "Compare: 8 > 1?" } }
      ],
      "transition": "highlight"
    },
    {
      "description": "8 > 1 is true — swap them",
      "actions": [
        { "type": "update", "target": "c2", "props": { "value": 1, "label": "1", "fill": "$danger" } },
        { "type": "update", "target": "c3", "props": { "value": 8, "label": "8", "fill": "$danger" } },
        { "type": "update", "target": "status", "props": { "text": "Yes! Swap 8 and 1 → [3, 5, 1, 8]" } }
      ],
      "transition": "swap"
    },
    {
      "description": "End of Pass 1. 8 is now in its final position (largest element bubbled to the end)",
      "actions": [
        { "type": "update", "target": "c2", "props": { "fill": "$default" } },
        { "type": "update", "target": "c3", "props": { "fill": "$success", "stroke": "$success" } },
        { "type": "update", "target": "status", "props": { "text": "Pass 1 complete: 8 is sorted" } }
      ]
    },
    {
      "description": "Pass 2: Compare elements at index 0 and 1",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c1", "props": { "fill": "$warning" } },
        { "type": "update", "target": "status", "props": { "text": "Compare: 3 > 5?" } },
        { "type": "update", "target": "pass_label", "props": { "text": "Pass 2 of 3" } }
      ],
      "transition": "highlight"
    },
    {
      "description": "3 > 5 is false — no swap needed",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$default" } },
        { "type": "update", "target": "c1", "props": { "fill": "$default" } },
        { "type": "update", "target": "status", "props": { "text": "No. 3 ≤ 5, no swap needed" } }
      ]
    },
    {
      "description": "Compare elements at index 1 and 2",
      "actions": [
        { "type": "update", "target": "c1", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c2", "props": { "fill": "$warning" } },
        { "type": "update", "target": "status", "props": { "text": "Compare: 5 > 1?" } }
      ],
      "transition": "highlight"
    },
    {
      "description": "5 > 1 is true — swap them",
      "actions": [
        { "type": "update", "target": "c1", "props": { "value": 1, "label": "1", "fill": "$danger" } },
        { "type": "update", "target": "c2", "props": { "value": 5, "label": "5", "fill": "$danger" } },
        { "type": "update", "target": "status", "props": { "text": "Yes! Swap 5 and 1 → [3, 1, 5, 8]" } }
      ],
      "transition": "swap"
    },
    {
      "description": "End of Pass 2. 5 is now in its final position",
      "actions": [
        { "type": "update", "target": "c1", "props": { "fill": "$default" } },
        { "type": "update", "target": "c2", "props": { "fill": "$success", "stroke": "$success" } },
        { "type": "update", "target": "status", "props": { "text": "Pass 2 complete: 5 and 8 are sorted" } }
      ]
    },
    {
      "description": "Pass 3: Compare elements at index 0 and 1",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$warning" } },
        { "type": "update", "target": "c1", "props": { "fill": "$warning" } },
        { "type": "update", "target": "status", "props": { "text": "Compare: 3 > 1?" } },
        { "type": "update", "target": "pass_label", "props": { "text": "Pass 3 of 3" } }
      ],
      "transition": "highlight"
    },
    {
      "description": "3 > 1 is true — swap them",
      "actions": [
        { "type": "update", "target": "c0", "props": { "value": 1, "label": "1", "fill": "$danger" } },
        { "type": "update", "target": "c1", "props": { "value": 3, "label": "3", "fill": "$danger" } },
        { "type": "update", "target": "status", "props": { "text": "Yes! Swap 3 and 1 → [1, 3, 5, 8]" } }
      ],
      "transition": "swap"
    },
    {
      "description": "Array is fully sorted: [1, 3, 5, 8]",
      "actions": [
        { "type": "update", "target": "c0", "props": { "fill": "$success", "stroke": "$success" } },
        { "type": "update", "target": "c1", "props": { "fill": "$success", "stroke": "$success" } },
        { "type": "update", "target": "status", "props": { "text": "Done! Array sorted: [1, 3, 5, 8]", "fill": "$success" } },
        { "type": "update", "target": "pass_label", "props": { "text": "Complete" } }
      ]
    }
  ]
}

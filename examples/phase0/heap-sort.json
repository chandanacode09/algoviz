            "stroke": "$text",
            "strokeWidth": 2,
            "fontSize": 14
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Extract 5. Remaining: [4, 1, 3]"
          }
        }
      ]
    },

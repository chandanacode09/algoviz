  "steps": [
    {
      "description": "Initial array: [4, 10, 3, 5, 1]. Start building max heap using heapify.",
      "actions": [
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Step 1: Build max heap via heapify process"
          }
        }
      ]
    },
    {
      "description": "Heapify: Compare parent 4 with children 10. Swap to maintain max heap property.",
      "actions": [
        {
          "type": "update",
          "target": "a0",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "a1",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Heapify: Swap 4 and 10 (parent-child violation)"
          }
        }
      ]
    },
    {
      "description": "Heapify completed: Max heap structure built. Root is 10 (maximum).",
      "actions": [
        {
          "type": "update",
          "target": "a0",
          "props": {
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "a1",
          "props": {
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Max heap built: root=10"
          }
        }
      ]
    },
    {
      "description": "Extract step 1: Remove root 10, move last element 1 to root, heapify down.",
      "actions": [
        {
          "type": "update",
          "target": "n0",
          "props": {
            "value": "1",
            "fill": "$danger"
          }
        },
        {
          "type": "create",
          "actor": {
            "id": "sorted-c0",
            "type": "cell",
            "x": 520,
            "y": 240,
            "width": 50,
            "height": 50,
            "value": "10",
            "fill": "$success",
            "stroke": "$text",
            "strokeWidth": 2,
            "fontSize": 14
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Extract 10 (max). Heapify new root."
          }
        }
      ]
    },
    {
      "description": "Heapify: 1 < 5 (right child). Swap. Now 5 is root. Heap: [5, 4, 3, 1].",
      "actions": [
        {
          "type": "update",
          "target": "n0",
          "props": {
            "value": "5"
          }
        },
        {
          "type": "update",
          "target": "n2",
          "props": {
            "value": "1"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Heapify: 1 sinks down, 5 becomes root"
          }
        }
      ]
    },
    {
      "description": "Extract step 2: Remove 5, place 1 at root, heapify.",
      "actions": [
        {
          "type": "update",
          "target": "n0",
          "props": {
            "value": "1",
            "fill": "$danger"
          }
        },
        {
          "type": "create",
          "actor": {
            "id": "sorted-c1",
            "type": "cell",
            "x": 580,
            "y": 240,
            "width": 50,
            "height": 50,
            "value": "5",

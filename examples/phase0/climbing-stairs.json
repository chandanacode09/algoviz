{
  "version": "1.0",
  "metadata": {
    "algorithm": "Climbing Stairs",
    "title": "Climbing Stairs DP",
    "description": "Count the number of ways to climb n=5 stairs when you can climb 1 or 2 steps at a time. Uses bottom-up DP where dp[i] = dp[i-1] + dp[i-2].",
    "category": "dynamic-programming",
    "complexity": {
      "time": "O(n)",
      "space": "O(n)"
    },
    "difficulty": "beginner",
    "inputDescription": "n=5: number of stairs to climb"
  },
  "config": {
    "canvas": {
      "width": 1000,
      "height": 400
    },
    "playback": {
      "stepDuration": 1000
    }
  },
  "actors": [
    {
      "id": "title",
      "type": "label",
      "x": 50,
      "y": 30,
      "text": "Climbing Stairs DP (n=5)",
      "fontSize": 24,
      "fontWeight": "bold",
      "fill": "$text"
    },
    {
      "id": "status",
      "type": "label",
      "x": 50,
      "y": 65,
      "text": "Ways to reach step i: dp[i] = dp[i-1] + dp[i-2]",
      "fontSize": 14,
      "fill": "$muted"
    },
    {
      "id": "cell_0",
      "type": "cell",
      "x": 120,
      "y": 150,
      "value": 0,
      "width": 60,
      "height": 60,
      "fill": "$default",
      "stroke": "$text",
      "textColor": "$text",
      "fontSize": 16
    },
    {
      "id": "cell_1",
      "type": "cell",
      "x": 200,
      "y": 150,
      "value": 0,
      "width": 60,
      "height": 60,
      "fill": "$default",
      "stroke": "$text",
      "textColor": "$text",
      "fontSize": 16
    },
    {
      "id": "cell_2",
      "type": "cell",
      "x": 280,
      "y": 150,
      "value": 0,
      "width": 60,
      "height": 60,
      "fill": "$default",
      "stroke": "$text",
      "textColor": "$text",
      "fontSize": 16
    },
    {
      "id": "cell_3",
      "type": "cell",
      "x": 360,
      "y": 150,
      "value": 0,
      "width": 60,
      "height": 60,
      "fill": "$default",
      "stroke": "$text",
      "textColor": "$text",
      "fontSize": 16
    },
    {
      "id": "cell_4",
      "type": "cell",
      "x": 440,
      "y": 150,
      "value": 0,
      "width": 60,
      "height": 60,
      "fill": "$default",
      "stroke": "$text",
      "textColor": "$text",
      "fontSize": 16
    },
    {
      "id": "cell_5",
      "type": "cell",
      "x": 520,
      "y": 150,
      "value": 0,
      "width": 60,
      "height": 60,
      "fill": "$default",
      "stroke": "$text",
      "textColor": "$text",
      "fontSize": 16
    },
    {
      "id": "index_label_0",
      "type": "label",
      "x": 145,
      "y": 230,
      "text": "0",
      "fontSize": 12,
      "fill": "$muted"
    },
    {
      "id": "index_label_1",
      "type": "label",
      "x": 225,
      "y": 230,
      "text": "1",
      "fontSize": 12,
      "fill": "$muted"
    },
    {
      "id": "index_label_2",
      "type": "label",
      "x": 305,
      "y": 230,
      "text": "2",
      "fontSize": 12,
      "fill": "$muted"
    },
    {
      "id": "index_label_3",
      "type": "label",
      "x": 385,
      "y": 230,
      "text": "3",
      "fontSize": 12,
      "fill": "$muted"
    },
    {
      "id": "index_label_4",
      "type": "label",
      "x": 465,
      "y": 230,
      "text": "4",
      "fontSize": 12,
      "fill": "$muted"
    },
    {
      "id": "index_label_5",
      "type": "label",
      "x": 545,
      "y": 230,
      "text": "5",
      "fontSize": 12,
      "fill": "$muted"
    },
    {
      "id": "pointer",
      "type": "pointer",
      "target": "cell_0",
      "position": "above",
      "label": "current",
      "fill": "$primary",
      "textColor": "$text"
    }
  ],
  "steps": [
    {
      "description": "Base case: dp[0] = 1 (one way to stay at start)",
      "actions": [
        {
          "type": "update",
          "target": "cell_0",
          "props": {
            "value": 1,
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "pointer",
          "props": {
            "target": "cell_0"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Base case: dp[0] = 1"
          }
        }
      ]
    },
    {
      "description": "Base case: dp[1] = 1 (one way to reach step 1)",
      "actions": [
        {
          "type": "update",
          "target": "cell_1",
          "props": {
            "value": 1,
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "pointer",
          "props": {
            "target": "cell_1"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Base case: dp[1] = 1"
          }
        }
      ]
    },
    {
      "description": "dp[2] = dp[1] + dp[0] = 1 + 1 = 2 (take 1 step or 2 steps)",
      "actions": [
        {
          "type": "update",
          "target": "cell_2",
          "props": {
            "value": 2,
            "fill": "$primary"
          }
        },
        {
          "type": "update",
          "target": "pointer",
          "props": {
            "target": "cell_2"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "dp[2] = dp[1] + dp[0] = 1 + 1 = 2"
          }
        }
      ]
    },
    {
      "description": "dp[3] = dp[2] + dp[1] = 2 + 1 = 3",
      "actions": [
        {
          "type": "update",
          "target": "cell_3",
          "props": {
            "value": 3,
            "fill": "$primary"
          }
        },
        {
          "type": "update",
          "target": "pointer",
          "props": {
            "target": "cell_3"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "dp[3] = dp[2] + dp[1] = 2 + 1 = 3"
          }
        }
      ]
    },
    {
      "description": "dp[4] = dp[3] + dp[2] = 3 + 2 = 5",
      "actions": [
        {
          "type": "update",
          "target": "cell_4",
          "props": {
            "value": 5,
            "fill": "$primary"
          }
        },
        {
          "type": "update",
          "target": "pointer",
          "props": {
            "target": "cell_4"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "dp[4] = dp[3] + dp[2] = 3 + 2 = 5"
          }
        }
      ]
    },
    {
      "description": "dp[5] = dp[4] + dp[3] = 5 + 3 = 8 (result)",
      "actions": [
        {
          "type": "update",
          "target": "cell_5",
          "props": {
            "value": 8,
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "pointer",
          "props": {
            "target": "cell_5"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Result: 8 ways to climb 5 stairs"
          }
        }
      ]
    }
  ]
}

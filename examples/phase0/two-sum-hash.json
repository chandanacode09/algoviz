{
  "metadata": {
    "title": "Two Sum with Hash Map",
    "description": "Find two numbers in array [2, 7, 11, 15] that add up to target 9 using hash map",
    "category": "hashing",
    "difficulty": "beginner",
    "complexity": {
      "time": "O(n)",
      "space": "O(n)"
    },
    "algorithm": "two_sum_hash"
  },

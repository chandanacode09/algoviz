      "anchor": "start"
    }
  ],
  "steps": [
    {
      "description": "Start: Initialize 4x4 board. Begin backtracking from row 0.",
      "actions": [
        {
          "type": "update",
          "target": "title",
          "props": {
            "opacity": 1
          }
        }
      ]
    },
    {
      "description": "Row 0: Try placing queen at position (0,0). Check if valid.",
      "actions": [
        {
          "type": "update",
          "target": "c0-0",
          "props": {
            "value": "Q",
            "fill": "$warning",
            "fontSize": 18
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Row 0: Queen placed at (0,0)"
          }
        }
      ]
    },
    {
      "description": "Row 1: Position (1,0) conflicts with queen at (0,0). Try next.",
      "actions": [
        {
          "type": "update",
          "target": "c1-0",
          "props": {
            "value": "X",
            "fill": "$danger",
            "fontSize": 14
          }
        }
      ]
    },
    {
      "description": "Row 1: Position (1,1) conflicts (diagonal). Try (1,2).",
      "actions": [
        {
          "type": "update",
          "target": "c1-0",
          "props": {
            "value": "",
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "c1-2",
          "props": {
            "value": "Q",
            "fill": "$warning",
            "fontSize": 18
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Row 1: Queen placed at (1,2)"
          }
        }
      ]
    },
    {
      "description": "Row 2: Try positions. (2,0) valid. Place queen at (2,0).",
      "actions": [
        {
          "type": "update",
          "target": "c2-0",
          "props": {
            "value": "Q",
            "fill": "$warning",
            "fontSize": 18
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Row 2: Queen placed at (2,0)"
          }
        }
      ]
    },
    {
      "description": "Row 3: No valid position. Backtrack from row 2. Remove queen at (2,0).",
      "actions": [
        {
          "type": "update",
          "target": "c2-0",
          "props": {
            "value": "",
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Backtracking: Row 2 has no solution"
          }
        }
      ]
    },
    {
      "description": "Row 2: Try position (2,3). Place queen. Continue to row 3.",
      "actions": [
        {
          "type": "update",
          "target": "c2-3",
          "props": {
            "value": "Q",
            "fill": "$warning",
            "fontSize": 18
          }
        },
        {
          "type": "update",
          "target": "c3-1",
          "props": {
            "value": "Q",
            "fill": "$success",
            "fontSize": 18
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Solution found! Queens at: (0,0), (1,2), (2,3), (3,1)"
          }
        }
      ]
    },
    {
      "description": "Complete: Valid 4-Queens solution displayed. All queens placed without conflicts.",
      "actions": [
        {
          "type": "update",
          "target": "title",
          "props": {
            "opacity": 1
          }
        }
      ]
    }

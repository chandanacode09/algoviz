          "type": "update",
          "target": "current-ptr",
          "props": {
            "target": "c2"
          }
        },
        {
          "type": "update",
          "target": "c2",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Comparing 4 with sorted portion. 2 < 4 < 5, insert at position 1."
          }
        }
      ],

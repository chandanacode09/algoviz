{
  "version": "1.0",
  "metadata": {
    "algorithm": "insertion_sort",
    "title": "Insertion Sort Visualization",
    "description": "Insertion sort on array [5, 2, 4, 6, 1, 3] with step-by-step element insertion",
    "category": "sorting",
    "complexity": {
      "time": "O(n²)",
      "space": "O(1)"
    },
    "difficulty": "beginner",
    "inputDescription": "Array of 6 integers: [5, 2, 4, 6, 1, 3]"
  },

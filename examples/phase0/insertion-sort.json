        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "1 inserted at start. Sorted portion: [1, 2, 4, 5, 6]"
          }
        }
      ],
      "description": "Step 8 of Insertion Sort Visualization"
    },
    {
      "actions": [
        {
          "type": "update",
          "target": "title",
          "props": {
            "text": "Insertion Sort - Complete"
          }
        },

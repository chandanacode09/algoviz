      "type": "label",
      "x": 500,
      "y": 350,
      "text": "First element [5] is considered sorted.",
      "fontSize": 14,
      "anchor": "middle"
    }
  ],
  "steps": [
    {
      "actions": [
        {
          "type": "update",
          "target": "title",
          "props": {
            "text": "Insertion Sort - Insert 2"
          }
        },
        {
          "type": "update",
          "target": "current-ptr",
          "props": {
            "target": "c1"
          }
        },
        {
          "type": "update",
          "target": "c1",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Comparing 2 with 5. 2 < 5, so shift 5 right."
          }
        }
      ],
      "description": "Step 1 of Insertion Sort Visualization"
    },
    {
      "actions": [
        {
          "type": "update",
          "target": "c0",
          "props": {
            "value": 2
          }
        },
        {
          "type": "update",
          "target": "c1",
          "props": {
            "value": 5,
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "sorted-region",
          "props": {
            "width": 160
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "2 inserted at position 0. Sorted portion: [2, 5]"
          }
        }
      ],
      "description": "Step 2 of Insertion Sort Visualization"
    },
    {
      "actions": [
        {
          "type": "update",
          "target": "title",
          "props": {
            "text": "Insertion Sort - Insert 4"

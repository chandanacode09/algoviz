      "type": "cell",
      "x": 200,
      "y": 200,
      "width": 60,
      "height": 60,
      "value": 5,
      "sublabel": "0",
      "fill": "$success"
    },
    {
      "id": "c1",
      "type": "cell",
      "x": 280,
      "y": 200,
      "width": 60,
      "height": 60,
      "value": 2,
      "sublabel": "1"
    },
    {
      "id": "c2",
      "type": "cell",
      "x": 360,
      "y": 200,
      "width": 60,
      "height": 60,
      "value": 4,
      "sublabel": "2"
    },
    {
      "id": "c3",
      "type": "cell",
      "x": 440,
      "y": 200,
      "width": 60,
      "height": 60,
      "value": 6,
      "sublabel": "3"
    },
    {
      "id": "c4",
      "type": "cell",
      "x": 520,
      "y": 200,
      "width": 60,
      "height": 60,
      "value": 1,
      "sublabel": "4"
    },
    {
      "id": "c5",
      "type": "cell",
      "x": 600,
      "y": 200,
      "width": 60,
      "height": 60,
      "value": 3,
      "sublabel": "5"
    },
    {

          "type": "update",
          "target": "c2",
          "props": {
            "value": 5
          }
        },
        {
          "type": "update",
          "target": "sorted-region",
          "props": {
            "width": 240
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "4 inserted. Sorted portion: [2, 4, 5]"
          }
        }
      ],
      "description": "Step 4 of Insertion Sort Visualization"
    },
    {
      "actions": [
        {
          "type": "update",
          "target": "title",
          "props": {
            "text": "Insertion Sort - Insert 6"
          }
        },
        {
          "type": "update",
          "target": "current-ptr",
          "props": {
            "target": "c3"
          }
        },
        {
          "type": "update",
          "target": "c3",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "Comparing 6 with sorted portion. 6 > 5, no shift needed."
          }
        }
      ],
      "description": "Step 5 of Insertion Sort Visualization"
    },
    {
      "actions": [
        {
          "type": "update",
          "target": "c3",
          "props": {
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "sorted-region",
          "props": {
            "width": 320
          }
        },
        {
          "type": "update",
          "target": "status",
          "props": {
            "text": "6 is already in correct position. Sorted portion: [2, 4, 5, 6]"
          }
        }

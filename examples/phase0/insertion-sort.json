    },
    {
      "actions": [
        {
          "type": "update",
          "target": "c0",
          "props": {
            "value": 1
          }
        },
        {
          "type": "update",
          "target": "c1",
          "props": {
            "value": 2
          }
        },
        {
          "type": "update",
          "target": "c2",
          "props": {
            "value": 4
          }
        },
        {
          "type": "update",
          "target": "c3",
          "props": {
            "value": 5
          }
        },
        {
          "type": "update",
          "target": "c4",

  "steps": [
    {
      "description": "Initialize: Preorder traversal starts at root. Visit root first, then left subtree, then right subtree.",
      "actions": [
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: "
          }
        }
      ]
    },
    {
      "description": "Visit node 1 (root). Add to output. Go to left subtree (node 2).",
      "actions": [
        {
          "type": "update",
          "target": "n1",
          "props": {
            "fill": "$warning"
          }
        },

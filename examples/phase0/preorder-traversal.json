          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: [1]"
          }
        }
      ]
    },
    {
      "description": "Visit node 2 (left child of 1). Add to output. Go to left subtree (node 4).",
      "actions": [
        {
          "type": "update",
          "target": "n1",
          "props": {
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "n2",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: [1, 2]"
          }
        }
      ]
    },
    {
      "description": "Visit node 4 (left child of 2). No children. Add to output. Backtrack to node 2.",
      "actions": [
        {
          "type": "update",
          "target": "n2",
          "props": {
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "n4",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: [1, 2, 4]"
          }
        }
      ]
    },
    {
      "description": "Visit node 5 (right child of 2). No children. Add to output. Backtrack to node 2, then to node 1.",
      "actions": [
        {
          "type": "update",
          "target": "n4",
          "props": {
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "n5",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: [1, 2, 4, 5]"
          }
        }
      ]
    },
    {
      "description": "Backtracked to 1. Now visit right subtree. Visit node 3. Add to output. Go to left subtree (node 6).",
      "actions": [
        {
          "type": "update",
          "target": "n5",
          "props": {
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "n3",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: [1, 2, 4, 5, 3]"
          }
        }
      ]
    },
    {
      "description": "Visit node 6 (left child of 3). Add to output. Then visit node 7 (right child of 3).",
      "actions": [
        {
          "type": "update",
          "target": "n3",
          "props": {
            "fill": "$default"
          }
        },
        {
          "type": "update",
          "target": "n6",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Order: [1, 2, 4, 5, 3, 6]"
          }
        }
      ]
    },
    {
      "description": "Complete: Preorder traversal finished. Final order: [1, 2, 4, 5, 3, 6, 7].",
      "actions": [
        {
          "type": "update",
          "target": "n6",
          "props": {
            "fill": "$success"
          }
        },
        {
          "type": "update",
          "target": "n7",
          "props": {
            "fill": "$warning"
          }
        },
        {
          "type": "update",
          "target": "output-text",
          "props": {
            "text": "Final: [1, 2, 4, 5, 3, 6, 7]"
          }
        },
        {
          "type": "update",
          "target": "n7",
          "props": {
            "fill": "$success"
          }
        }
      ]
    }
